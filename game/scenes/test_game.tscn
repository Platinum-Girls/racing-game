[sub_resource type="GDScript" id="GDScript_7xj4p"]
resource_name = "VehicleSwitcher"
script/source = "extends Node

@export var car: CarBase
@export var vehicles: Array[PackedScene]

var current: int = 0

func _ready() -> void:
	switch()

func _input(event: InputEvent) -> void:
	if event.is_action_pressed(&\"switch_vehicle\"):
		switch()
		car.setup_visual()
		
func switch() -> void:
	current += 1
	if current >= vehicles.size(): current = 0
	
	if car.visual: 
		car.visual.queue_free()
	car.mesh_scene = vehicles[current]
"

